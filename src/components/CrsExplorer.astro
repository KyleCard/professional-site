---
import { CRS } from "../data/crs";
import {
  renderPlot, renderTrack, readout, tallyRows, renderProfileRows,
  renderDensity, densityStats, genComponents, type MixComp,
  renderFieldBg, renderFieldMarker, localCrs, fmtCRS,
  renderSurface, renderWalkTrail, walkValues, walkVolatility, walkReading, RUGGED_EPS,
  surfaceAt, renderChartAxes, renderChartTraces,
} from "../scripts/crs-core";

// ---- Layer 1 server render (no-JS / pre-hydration fallback) ----
const reps0 = CRS.layer1.replicates;
const plot0 = renderPlot(reps0, CRS.axis, CRS.layer1.drug);
const r0 = readout(reps0, CRS.axis);
const track0 = renderTrack(r0.crs);
const tally0 = tallyRows(r0.res, r0.sen, r0.base);

// ---- Layer 2 server render (both pathway profiles, for no-JS) ----
const [pw1, pw2] = CRS.pathways;
const rows1 = renderProfileRows(CRS.drugs, pw1.crs);
const rows2 = renderProfileRows(CRS.drugs, pw2.crs);

// ---- Layer 3: distribution for a pathway+drug (explicit override or generated) ----
const compsFor = (pw: number, drug: number): MixComp[] =>
  CRS.distributions[`${CRS.pathways[pw].id}:${CRS.drugs[drug]}`]?.components ?? genComponents(CRS.pathways[pw].crs[drug]);
const dens0 = renderDensity(compsFor(0, 0), CRS.pathways[0].crs[0]); // default = Pathway 1, Drug A
// no-JS fallback: two contrasting examples
const exConf = compsFor(0, 0), exUnc = compsFor(0, 3);
const densConf = renderDensity(exConf, CRS.pathways[0].crs[0]);
const densUnc = renderDensity(exUnc, CRS.pathways[0].crs[3]);
const readConf = densityStats(exConf).reading;
const readUnc = densityStats(exUnc).reading;

// ---- Layer 4: context field (a "landscape of predictability") ----
const ex = CRS.context.example;
// no-JS field = static landscape + two labelled sample points (lab/low, host/high)
const field0 =
  renderFieldBg(CRS.context) +
  `<g class="crs-fmarkers">${renderFieldMarker(0, 0, ex)}${renderFieldMarker(1, 1, ex)}</g>`;
const cLab = fmtCRS(localCrs(0, 0, ex));   // confident lab value (= baseCrs)
const cHost = fmtCRS(localCrs(1, 1, ex));  // host-like corner (≈ 0)
// interactive readout's initial state (lab/low corner; JS re-renders on hydrate)
const fComps0 = genComponents(localCrs(0, 0, ex));
const fdens0 = renderDensity(fComps0, localCrs(0, 0, ex));
const fread0 = densityStats(fComps0).reading;

// ---- Layer 5: predictability of the shift (drag a marker along the path) ----
const l5 = CRS.layer5;
const l5axes = CRS.context.axes;
const surf5 = [0, 1].map((pw) => renderSurface(l5, pw, l5axes));
const trail5 = [0, 1].map((pw) => renderWalkTrail(l5, pw, 1)); // no-JS twin: full static trail
const chartAxes5 = renderChartAxes(l5, l5axes);
const chartBoth5 = renderChartTraces(l5, 0, 1, 1);   // no-JS: both pathways traced in full
const markerInit5 = renderWalkTrail(l5, 0, 0);       // interactive: marker at the start corner
const chartInit5 = renderChartTraces(l5, 0, 0, 0);   // interactive: nothing traced yet
const startVal5 = fmtCRS(surfaceAt(0, 0, l5, 0));
const l5tags = [0, 1].map((pw) => ({
  label: CRS.pathways[pw].label,
  rugged: walkVolatility(walkValues(l5, pw)) > RUGGED_EPS,
  reading: walkReading(l5, pw),
}));
---
<section class="crs" aria-labelledby="crs-h">
  <div class="wrap">
    <p class="card-lab mono reveal">The Card Lab · interactive</p>
    <h2 class="title crs-title reveal" id="crs-h">Will the next drug <span class="peak">work?</span></h2>
    <p class="crs-intro measure reveal">
      When a pathogen evolves resistance to one antibiotic, its susceptibility to others can change. The
      <strong>Collateral Response Score</strong> captures the <em>direction</em> of that change
      and its <em>predictability</em>.
    </p>

    <div class="crs-card reveal">
      <div class="crs-tabs" role="tablist" aria-label="CRS Explorer">
        <button role="tab" id="crs-tab-1" aria-controls="crs-panel-1" aria-selected="true" class="crs-tab" type="button">
          <span class="crs-tab-n mono">01</span> Calculator</button>
        <button role="tab" id="crs-tab-2" aria-controls="crs-panel-2" aria-selected="false" tabindex="-1" class="crs-tab" type="button">
          <span class="crs-tab-n mono">02</span> Pathways</button>
        <button role="tab" id="crs-tab-3" aria-controls="crs-panel-3" aria-selected="false" tabindex="-1" class="crs-tab" type="button">
          <span class="crs-tab-n mono">03</span> Distribution</button>
        <button role="tab" id="crs-tab-4" aria-controls="crs-panel-4" aria-selected="false" tabindex="-1" class="crs-tab" type="button">
          <span class="crs-tab-n mono">04</span> Context</button>
        <button role="tab" id="crs-tab-5" aria-controls="crs-panel-5" aria-selected="false" tabindex="-1" class="crs-tab" type="button">
          <span class="crs-tab-n mono">05</span> Reliability</button>
      </div>

      <!-- ───────── PANEL 1 · Layer 1 calculator ───────── -->
      <div role="tabpanel" id="crs-panel-1" aria-labelledby="crs-tab-1" class="crs-panel" data-crs-root>
        <h3 class="crs-panel-h">Live CRS calculator</h3>
        <p class="crs-lead">
          <strong>See how the CRS is calculated.</strong> Each dot below represents a replicate population, evolved separately and measured
          against a second drug. The CRS captures the overall <em>direction</em> of change in 
          second-line drug susceptibility relative to the ancestor (sign) and the <em>predictability</em> of that change (magnitude).
          Notice that a given score can arise in two very different ways: when populations are split between resistance and sensitivity, 
          or when there is consistent change across replicates. Toggle between the Worked Example and Full Agreement presets to observe this distinction.
        </p>
        <p class="crs-howto mono" id="crs-howto">
          Tip: Drag the dots, or focus a dot and nudge it with <kbd>↑</kbd> <kbd>↓</kbd>, to watch the score respond. Use the <kbd>−</kbd> <kbd>+</kbd> buttons to change the replicate count.
        </p>

        <div class="crs-grid">
          <div class="crs-plot-wrap">
            <svg id="crs-plot" class="crs-plot" viewBox="0 0 380 360" aria-describedby="crs-howto"
              role="group" aria-label="Single-drug replicate plot; drag dots up for collateral resistance, down for sensitivity" set:html={plot0}></svg>
          </div>

          <div class="crs-output">
            <p class="crs-tracklab mono">Collateral Response Score (CRS)</p>
            <svg id="crs-track" class="crs-track" viewBox="0 0 380 88" role="img"
              aria-label="Collateral Response Score, from minus one to plus one" set:html={track0}></svg>
            <table class="crs-tally">
              <caption class="visually-hidden">Replicate outcomes</caption>
              <tbody id="crs-tally" set:html={tally0}></tbody>
            </table>
            <p id="crs-interp" class="crs-interp">{r0.interp}</p>
            <p id="crs-live" class="visually-hidden" aria-live="polite">{r0.live}</p>
          </div>

          <div class="crs-side">
            <div class="crs-count">
              <span class="crs-cap mono">Replicates</span>
              <div class="crs-stepper">
                <button type="button" class="crs-btn" data-crs="dec" aria-label="Remove a replicate">−</button>
                <span id="crs-count" class="crs-num">{reps0.length}</span>
                <button type="button" class="crs-btn" data-crs="inc" aria-label="Add a replicate">+</button>
              </div>
            </div>
            <div class="crs-presets">
              <span class="crs-cap mono">Try a preset</span>
              <div class="crs-chips">
                {CRS.layer1.presets.map((p) => (
                  <button type="button" class="crs-chip" data-preset={p.id} title={p.note}>{p.label}</button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ───────── PANEL 2 · Layer 2 pathway profile ───────── -->
      <div role="tabpanel" id="crs-panel-2" aria-labelledby="crs-tab-2" class="crs-panel" data-crs-pathways>
        <h3 class="crs-panel-h">Pathway collateral profile</h3>
        <p class="crs-lead">
          <strong>The same drug, two different outcomes.</strong> A population may evolve antibiotic resistance through different 
          genetic pathways. Its collateral response to other drugs can change depending on which route the population takes. 
          Toggle between two evolutionary pathways below and watch the collateral profile invert across several second-line drugs:
          knowing <em>how</em> resistance evolved is often as useful as knowing <em>that</em> it evolved.
        </p>

        <!-- interactive (revealed by JS) -->
        <div class="crs-pwrap" hidden>
          <div class="crs-toggle" role="radiogroup" aria-label="Evolutionary pathway">
            <button type="button" role="radio" aria-checked="true" class="crs-pw-btn active" data-pw="0">Pathway 1</button>
            <button type="button" role="radio" aria-checked="false" tabindex="-1" class="crs-pw-btn" data-pw="1">Pathway 2</button>
          </div>
          <div class="crs-profile" id="crs-profile"></div>
          <p class="crs-pcap">Knowing which route a pathogen took tells a clinician which second-line drugs will still work.
            In this example, an early fork yields opposite, partly predictable collateral profiles.</p>
          <p class="visually-hidden" aria-live="polite" id="crs-pw-live"></p>
        </div>

        <!-- no-JS fallback: both profiles, side by side -->
        <div class="crs-pfallback">
          <div class="crs-pcol"><p class="crs-pcol-h mono">{pw1.label}</p><div class="crs-profile" set:html={rows1}></div></div>
          <div class="crs-pcol"><p class="crs-pcol-h mono">{pw2.label}</p><div class="crs-profile" set:html={rows2}></div></div>
        </div>
      </div>

      <!-- ───────── PANEL 3 · Layer 3 distribution ───────── -->
      <div role="tabpanel" id="crs-panel-3" aria-labelledby="crs-tab-3" class="crs-panel" data-crs-dist>
        <h3 class="crs-panel-h">CRS as a distribution</h3>
        <p class="crs-lead">
          <strong>A single number can obscure how sure we really are.</strong> Each CRS value is an estimate, not a verdict,
          because it is drawn from a limited sample of replicates that could have landed differently by chance. Resampling
          gives a distribution, with its <em>width</em> providing actionable information: narrow and far from zero is a confident
          call; wide, or straddling zero, means a clinician genuinely cannot say which way evolution will go. The shape of
          the distribution is often more informative than the number itself.</p>

        <!-- interactive (revealed by JS) -->
        <div class="crs-dwrap" hidden>
          <div class="crs-dctl">
            <div class="crs-toggle" role="radiogroup" aria-label="Evolutionary pathway">
              <button type="button" role="radio" aria-checked="true" class="crs-pw-btn active" data-dpw="0">Pathway 1</button>
              <button type="button" role="radio" aria-checked="false" tabindex="-1" class="crs-pw-btn" data-dpw="1">Pathway 2</button>
            </div>
            <div class="crs-drugsel" role="radiogroup" aria-label="Second-line drug">
              {CRS.drugs.map((d, i) => (
                <button type="button" role="radio" aria-checked={i === 0 ? "true" : "false"} tabindex={i === 0 ? 0 : -1} class={`crs-drug-btn${i === 0 ? " active" : ""}`} data-drug={i}>{d}</button>
              ))}
            </div>
          </div>
          <svg id="crs-density" class="crs-density" viewBox="0 0 380 184" role="img"
            aria-label="Distribution of the Collateral Response Score" set:html={dens0}></svg>
          <p id="crs-dread" class="crs-dread">{densityStats(compsFor(0, 0)).reading}</p>
          <p class="visually-hidden" aria-live="polite" id="crs-dlive"></p>
        </div>

        <!-- no-JS fallback: a confident vs an uncertain example -->
        <div class="crs-dfallback">
          <figure class="crs-dex">
            <figcaption class="crs-pcol-h mono">Confident — narrow, far from zero</figcaption>
            <svg class="crs-density" viewBox="0 0 380 184" role="img" aria-label="A narrow distribution far from zero" set:html={densConf}></svg>
            <p class="crs-dread">{readConf}</p>
          </figure>
          <figure class="crs-dex">
            <figcaption class="crs-pcol-h mono">Uncertain — wide, straddling zero</figcaption>
            <svg class="crs-density" viewBox="0 0 380 184" role="img" aria-label="A wide distribution straddling zero" set:html={densUnc}></svg>
            <p class="crs-dread">{readUnc}</p>
          </figure>
        </div>
      </div>

      <!-- ───────── PANEL 4 · Layer 4 context landscape ───────── -->
      <div role="tabpanel" id="crs-panel-4" aria-labelledby="crs-tab-4" class="crs-panel" data-crs-context>
        <h3 class="crs-panel-h">CRS across contexts</h3>
        <p class="crs-lead">
          <strong>Confidence is context-dependent.</strong> 
          A clinician's ability to predict a treatment outcome can depend on the environmental context in which evolution happens. 
          In the preceding examples, we assumed the CRS and its distributions were measured in a simplified, laboratory environment. 
          But a bacterium evolving inside an inflamed human airway faces different selective pressures than one evolving in a flask, 
          and a collateral response that appears reliable in one setting may become less certain in another.
          </p>
        <p class="crs-howto mono">
          Tip: Drag the marker across the field, or focus it and use <kbd>↑</kbd> <kbd>↓</kbd> <kbd>←</kbd> <kbd>→</kbd>.</p>

        <div class="crs-fgrid">
          <div class="crs-field-wrap">
            <svg id="crs-field" class="crs-field" viewBox="0 0 380 360" role="group"
              aria-label="Context field: environment on the horizontal axis, inflammation on the vertical axis; colour and contours show the local Collateral Response Score" set:html={field0}></svg>
            <div class="crs-flegend" aria-hidden="true">
              <span class="crs-fleg-cap mono">CRS</span>
              <span class="crs-fleg-bar"></span>
              <span class="crs-fleg-ends mono"><span>{cLab} · confident</span><span>0 · uncertain</span></span>
            </div>
          </div>

          <div class="crs-fside">
            <!-- interactive readout (revealed by JS) -->
            <div class="crs-fwrap" hidden>
              <p class="crs-cap mono">Local CRS at the marker</p>
              <p class="crs-fval" id="crs-fval">{cLab}</p>
              <svg id="crs-fdens" class="crs-density" viewBox="0 0 380 184" role="img"
                aria-label="Distribution of the local Collateral Response Score at the marker" set:html={fdens0}></svg>
              <p class="crs-dread" id="crs-fread">{fread0}</p>
              <p class="visually-hidden" aria-live="polite" id="crs-flive"></p>
            </div>

            <!-- no-JS fallback: the two labelled sample points -->
            <div class="crs-ffallback">
              <p class="crs-fsample"><span class="crs-fkey mono">Lab medium · low inflammation</span> → CRS <b>{cLab}</b> — a confident, actionable call.</p>
              <p class="crs-fsample"><span class="crs-fkey mono">Airway-on-chip · high inflammation</span> → CRS <b>{cHost}</b> — predictability collapses.</p>
            </div>
          </div>
        </div>

        <p class="crs-pcap">
        In the illustration above, a population appears confidently collaterally sensitive to an antibiotic in a standard lab medium (CRS = {cLab}). 
        However, as the environment becomes more host-like and inflamed, that confidence trends toward zero. 
        The <strong>Evolution-on-a-Chip platform</strong>, which monitors host-like microenvironments in real time using sensors, is designed to investigate whether and 
        how environmental context reshapes CRS.
        </p>
      </div>

      <!-- ───────── PANEL 5 · Layer 5 predictability of the shift ───────── -->
      <div role="tabpanel" id="crs-panel-5" aria-labelledby="crs-tab-5" class="crs-panel" data-crs-shift>
        <h3 class="crs-panel-h">Is the shift itself predictable?</h3>
        <p class="crs-lead">
          <strong> Is the change in CRS <em>predictable</em> or <em>idiosyncratic</em> across an environmental gradient?</strong> 
          This question arises from two key points already established: (i.) an infection’s response to a second 
          antibiotic depends on the genetic pathway the population took as it evolved resistance against a first-line agent, 
          and (ii.) that response can also shift across an environmental gradient. Confidence that a given treatment will 
          work (captured by the CRS) can depend on both.
        </p>
        <p class="crs-lead">
          Below, observe how a population's collateral response changes as the conditions shift from a standard lab medium to a fully host-like, 
          inflamed environment. For populations that evolved along Pathway 1, the change in CRS is predictable with a steady, uniform increase. 
          For Pathway 2 populations, an identical environmental shift leads to idiosyncratic outcomes: the CRS increases,
          reverses direction, and then increases again. Using the <strong>Evolution-on-a-Chip</strong> platform, we will assess how reliably 
          treatment predictions hold across changing conditions.
        </p>
        <p class="crs-howto mono">
          Tip: Drag the marker along the diagonal from lab medium (bottom-left) toward the inflamed airway-on-chip (top-right);
          the chart traces the score as you go. Focus the marker and step with <kbd>←</kbd> <kbd>→</kbd>. Switch pathways to
          overlay both traces.
        </p>

        <!-- interactive (revealed by JS): one surface + a live-building chart -->
        <div class="crs-dwrap2" hidden>
          <div class="crs-toggle" role="radiogroup" aria-label="Evolutionary pathway">
            <button type="button" role="radio" aria-checked="true" class="crs-pw-btn active" data-dw-pw="0">Pathway 1</button>
            <button type="button" role="radio" aria-checked="false" tabindex="-1" class="crs-pw-btn" data-dw-pw="1">Pathway 2</button>
          </div>

          <div class="crs-shiftgrid">
            <figure class="crs-spanel">
              <figcaption class="crs-scap">
                <span class="crs-pcol-h mono" id="crs-dw-plabel">{l5tags[0].label}</span>
                <span class={`crs-stag ${l5tags[0].rugged ? "rugged" : "smooth"}`} id="crs-dw-ptag">{l5tags[0].rugged ? "rugged" : "smooth"}</span>
              </figcaption>
              <svg class="crs-surface-svg" id="crs-dw-surf" viewBox="0 0 380 360" role="group"
                aria-label="Predictability surface. Drag the marker along the diagonal path from the lab-media corner to the inflamed-chip corner.">
                <g class="crs-surf-layer" id="crs-dw-surflayer" set:html={surf5[0]} />
                <g class="crs-walk-g" id="crs-dw-marker" set:html={markerInit5} />
              </svg>
            </figure>

            <figure class="crs-chartfig">
              <figcaption class="crs-pcol-h mono">CRS along the path</figcaption>
              <svg class="crs-chart-svg" id="crs-dw-chart" viewBox="0 0 380 300" role="img"
                aria-label="Line chart of the Collateral Response Score along the path from a lab medium, uninflamed, to the airway-on-chip, inflamed.">
                <g class="crs-chart-axes" set:html={chartAxes5} />
                <g class="crs-chart-traces" id="crs-dw-traces" set:html={chartInit5} />
              </svg>
            </figure>
          </div>

          <div class="crs-dw-foot">
            <p class="crs-dw-readout"><span class="crs-cap mono">Current CRS</span><span class="crs-dw-val" id="crs-dw-val">{startVal5}</span></p>
            <button type="button" class="crs-dw-reset" id="crs-dw-reset">Reset traces</button>
          </div>
          <p class="visually-hidden" aria-live="polite" id="crs-dw-live"></p>
        </div>

        <!-- no-JS fallback: both surfaces + both full traces on the chart -->
        <div class="crs-shiftfallback">
          <div class="crs-twin">
            {l5tags.map((p, pw) => (
              <figure class="crs-spanel">
                <figcaption class="crs-scap"><span class="crs-pcol-h mono">{p.label}</span>
                  <span class={`crs-stag ${p.rugged ? "rugged" : "smooth"}`}>{p.rugged ? "rugged" : "smooth"}</span></figcaption>
                <svg class="crs-surface-svg" viewBox="0 0 380 360" role="img" aria-label={`Predictability surface, ${p.label}, with the full diagonal path drawn.`}>
                  <g set:html={surf5[pw]} /><g set:html={trail5[pw]} />
                </svg>
              </figure>
            ))}
          </div>
          <figure class="crs-chartfig">
            <figcaption class="crs-pcol-h mono">CRS along the path — both pathways</figcaption>
            <svg class="crs-chart-svg" viewBox="0 0 380 300" role="img"
              aria-label="Both pathways' Collateral Response Score traced along the full path; same endpoints, different reliability.">
              <g set:html={chartAxes5} /><g set:html={chartBoth5} />
            </svg>
            <p class="crs-clegend mono"><span class="crs-lg-active">■ {l5tags[0].label}</span> · <span class="crs-lg-ghost">■ {l5tags[1].label}</span></p>
          </figure>
        </div>

        <p class="crs-pcap">
          In the illustration above, both journeys begin and end at the same score. For <strong>Pathway 1</strong> evolved populations, there is a steady, 
          predictable slope as the environmental gradient changes (from CRS −0.70 → 0.00). For <strong>Pathway 2</strong> evolved populations, the path 
          is idiosyncratic: small context shifts swing the score despite the same endpoints. 
          Same destination, very different reliability. We will investigate that reliability using the <strong>Evolution-on-a-Chip</strong> platform.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .crs { position: relative; z-index: var(--z-content); padding: var(--s-6) 0 var(--s-7);
    background: linear-gradient(180deg, var(--paper) 0%, var(--paper-warm) 100%); }
  .crs-title { font-size: var(--t-h2); margin-bottom: var(--s-3); }
  .crs-title .peak { color: var(--amber); }
  .crs-intro { color: var(--ink-soft); font-size: var(--t-lede); margin-bottom: var(--s-5); }
  .crs-intro strong { color: var(--ink); font-weight: 600; }
  .crs-intro em { font-style: italic; color: var(--teal); }

  .crs-card { background: var(--paper-panel); border: 1px solid var(--rule); border-radius: var(--radius);
    padding: clamp(20px, 3vw, 36px); box-shadow: 0 24px 60px -44px rgba(34, 45, 42, .5); }

  /* tabs (hidden until JS; without JS, panels stack with their headings) */
  .crs-tabs { display: none; gap: 4px; border-bottom: 1px solid var(--rule); margin-bottom: var(--s-4); }
  .crs-card.js-tabs .crs-tabs { display: flex; }
  .crs-tab { background: none; border: 0; border-bottom: 2px solid transparent; margin-bottom: -1px;
    padding: 10px 16px; color: var(--slate); font-family: var(--font-body); font-size: 1rem; cursor: pointer;
    display: inline-flex; align-items: baseline; gap: 8px; }
  .crs-tab:hover { color: var(--ink); }
  .crs-tab[aria-selected="true"] { color: var(--ink); border-bottom-color: var(--teal); }
  .crs-tab-n { color: var(--slate); font-size: .7rem; }
  .crs-tab[aria-selected="true"] .crs-tab-n { color: var(--teal); }
  .crs-panel-h { font-family: var(--font-display); font-size: var(--t-h3); margin-bottom: var(--s-3); color: var(--ink); }
  .crs-card.js-tabs .crs-panel-h { display: none; }
  .crs-panel + .crs-panel { margin-top: var(--s-6); }
  .crs-card.js-tabs .crs-panel + .crs-panel { margin-top: 0; }

  /* finalized intro prose that sits above each layer's interactive */
  .crs-lead { color: var(--ink-soft); font-size: 1.05rem; line-height: 1.6; margin-bottom: var(--s-3); max-width: 64ch; }
  .crs-lead strong { color: var(--ink); font-weight: 600; }
  .crs-lead em { font-style: italic; color: var(--teal); }
  /* small utility "how to interact" microcopy (kept distinct from the verbatim intro) */
  .crs-howto { color: var(--slate); margin-bottom: var(--s-4); text-transform: none; letter-spacing: .02em; line-height: 1.5; }
  .crs-howto kbd { font-family: var(--font-mono); background: var(--paper); border: 1px solid var(--rule);
    border-radius: 3px; padding: 0 5px; font-size: .85em; }

  /* ---- Layer 1 ---- */
  .crs-grid { display: grid; grid-template-columns: minmax(0, 460px) 200px;
