    background: linear-gradient(90deg, rgb(40, 74, 84), rgb(214, 204, 182)); }
  .crs-fleg-ends { grid-area: ends; display: flex; justify-content: space-between; color: var(--slate); font-size: .68rem; }

  .crs-fside { align-self: center; }
  .crs-fwrap { text-align: center; }
  .crs-fwrap[hidden], .crs-ffallback[hidden] { display: none; }
  .crs-fval { font-family: var(--font-display); font-size: clamp(2rem, 1.4rem + 2vw, 2.8rem); font-weight: 500;
    color: var(--ink); line-height: 1; margin: 4px 0 var(--s-3); }
  .crs-fwrap .crs-density { max-width: 320px; }
  .crs-fwrap .crs-dread { font-size: .98rem; margin-top: var(--s-2); }
  .crs-ffallback { display: flex; flex-direction: column; gap: var(--s-3); }
  .crs-fsample { color: var(--ink-soft); font-size: .98rem; line-height: 1.5; }
  .crs-fsample b { color: var(--ink); font-family: var(--font-mono); }
