  .crs-field :global(.crs-fmark-dot) { stroke: var(--ink); stroke-width: 2; }
  .crs-field :global(.crs-fmark-val) { font-family: var(--font-display); font-size: 16px; font-weight: 500; fill: var(--ink);
    paint-order: stroke; stroke: var(--paper-panel); stroke-width: 3.5px; stroke-linejoin: round; }

  .crs-flegend { display: grid; grid-template-columns: auto 1fr; grid-template-areas: "cap bar" "cap ends";
