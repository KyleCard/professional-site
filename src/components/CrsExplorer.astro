</style>

<script>
  import { CRS } from "../data/crs";
  import {
    renderPlot, renderTrack, readout, tallyRows, renderProfileRows, profileSummary,
    renderDensity, densityStats, genComponents,
    valueToY, yToValue, valueText, clamp, snap, crsToTrackX, crsMiniX, fmtCRS, PLOT,
    renderFieldMarker, localCrs, fieldColor, clamp01, fieldX, fieldY, xToEnv, yToInflam, FIELD,
    walkValues, walkVolatility, surfaceAt, surfaceColor, diagTFromXY, renderSurface, renderChartTraces,
  } from "../scripts/crs-core";

  // ── accessible tabs ──────────────────────────────────────────────
  class Tabs {
    tabs: HTMLElement[]; panels: HTMLElement[];
    constructor(card: HTMLElement) {
      this.tabs = [...card.querySelectorAll<HTMLElement>('[role="tab"]')];
      this.panels = this.tabs.map((t) => card.querySelector<HTMLElement>("#" + t.getAttribute("aria-controls")!)!);
      card.classList.add("js-tabs");
      this.tabs.forEach((tab, i) => {
        tab.addEventListener("click", () => this.go(i, true));
        tab.addEventListener("keydown", (e) => {
          const n = e.key === "ArrowRight" ? i + 1 : e.key === "ArrowLeft" ? i - 1
            : e.key === "Home" ? 0 : e.key === "End" ? this.tabs.length - 1 : -1;
          if (n < 0) return; e.preventDefault();
          this.go((n + this.tabs.length) % this.tabs.length, true);
        });
      });
      this.go(0, false);
    }
    go(i: number, focus: boolean) {
      this.tabs.forEach((t, j) => { const s = j === i; t.setAttribute("aria-selected", s ? "true" : "false"); t.tabIndex = s ? 0 : -1; });
      this.panels.forEach((p, j) => { p.hidden = j !== i; });
      if (focus) this.tabs[i].focus();
    }
  }

  // ── Layer 1 calculator ───────────────────────────────────────────
  class CrsCalc {
    root: HTMLElement; a = CRS.axis; drug = CRS.layer1.drug;
    reps: number[] = [...CRS.layer1.replicates]; sel = -1;
    plot: SVGSVGElement; track: SVGSVGElement;
    interpEl: HTMLElement; tallyEl: HTMLElement; liveEl: HTMLElement; countEl: HTMLElement;
    marker: SVGGElement | null = null; markerVal: SVGTextElement | null = null;
    constructor(root: HTMLElement) {
      this.root = root;
      this.plot = root.querySelector("#crs-plot")!;
      this.track = root.querySelector("#crs-track")!;
      this.interpEl = root.querySelector("#crs-interp")!;
      this.tallyEl = root.querySelector("#crs-tally")!;
      this.liveEl = root.querySelector("#crs-live")!;
      this.countEl = root.querySelector("#crs-count")!;
      root.classList.add("crs-ready");
      root.querySelector('[data-crs="inc"]')!.addEventListener("click", () => this.setCount(this.reps.length + 1));
      root.querySelector('[data-crs="dec"]')!.addEventListener("click", () => this.setCount(this.reps.length - 1));
      root.querySelectorAll<HTMLElement>("[data-preset]").forEach((b) =>
        b.addEventListener("click", () => this.applyPreset(b.dataset.preset!)));
      this.render();
    }
    render() {
      const r = readout(this.reps, this.a);
      this.plot.innerHTML = renderPlot(this.reps, this.a, this.drug, this.sel);
      this.track.innerHTML = renderTrack(r.crs);
      this.marker = this.track.querySelector(".crs-marker");
      this.markerVal = this.track.querySelector(".crs-marker-val");
      this.tallyEl.innerHTML = tallyRows(r.res, r.sen, r.base);
      this.interpEl.textContent = r.interp;
      this.bindDots();
    }
    bindDots() {
      this.plot.querySelectorAll<SVGCircleElement>(".crs-dot").forEach((dot) => {
        const i = Number(dot.dataset.i);
        dot.addEventListener("pointerdown", (e) => this.startDrag(e, dot, i));
        dot.addEventListener("keydown", (e) => this.onKey(e, dot, i));
        dot.addEventListener("focus", () => { this.sel = i; });
      });
    }
    valueAt(clientY: number) {
      const r = this.plot.getBoundingClientRect();
      return clamp(snap(yToValue(((clientY - r.top) / r.height) * PLOT.h, this.a), this.a), this.a);
    }
    startDrag(e: PointerEvent, dot: SVGCircleElement, i: number) {
      e.preventDefault(); dot.focus(); this.sel = i; dot.setPointerCapture?.(e.pointerId);
      const move = (ev: PointerEvent) => { this.reps[i] = this.valueAt(ev.clientY); this.updateDot(dot, i); this.refresh(false); };
      const up = () => { dot.releasePointerCapture?.(e.pointerId); dot.removeEventListener("pointermove", move); dot.removeEventListener("pointerup", up); this.refresh(true); };
      dot.addEventListener("pointermove", move); dot.addEventListener("pointerup", up);
    }
    onKey(e: KeyboardEvent, dot: SVGCircleElement, i: number) {
      let v = this.reps[i];
      if (e.key === "ArrowUp" || e.key === "ArrowRight") v += this.a.step;
      else if (e.key === "ArrowDown" || e.key === "ArrowLeft") v -= this.a.step;
      else if (e.key === "Home") v = this.a.max; else if (e.key === "End") v = this.a.min; else return;
      e.preventDefault(); this.reps[i] = clamp(snap(v, this.a), this.a); this.updateDot(dot, i); this.refresh(true);
    }
    updateDot(dot: SVGCircleElement, i: number) {
      const v = this.reps[i], eps = this.a.step / 2;
      dot.setAttribute("cy", valueToY(v, this.a).toFixed(1));
      dot.setAttribute("class", `crs-dot ${v > eps ? "pos" : v < -eps ? "neg" : "zero"}${i === this.sel ? " sel" : ""}`);
      dot.setAttribute("aria-valuenow", v.toFixed(2)); dot.setAttribute("aria-valuetext", valueText(v, this.a));
    }
    refresh(announce: boolean) {
      const r = readout(this.reps, this.a);
      if (this.marker) this.marker.setAttribute("transform", `translate(${crsToTrackX(r.crs).toFixed(1)} 0)`);
      if (this.markerVal) this.markerVal.textContent = fmtCRS(r.crs);
      this.tallyEl.innerHTML = tallyRows(r.res, r.sen, r.base);
      this.interpEl.textContent = r.interp;
      if (announce) this.liveEl.textContent = r.live;
    }
    setCount(n: number) {
      n = Math.max(CRS.layer1.minReplicates, Math.min(CRS.layer1.maxReplicates, n));
      if (n === this.reps.length) return;
      while (this.reps.length < n) this.reps.push(0); this.reps.length = n;
      this.countEl.textContent = String(n); this.sel = -1; this.render();
      this.liveEl.textContent = `${n} replicates. ${readout(this.reps, this.a).live}`;
    }
    applyPreset(id: string) {
      const p = CRS.layer1.presets.find((x) => x.id === id); if (!p) return;
      this.reps = [...p.replicates]; this.countEl.textContent = String(this.reps.length);
      this.sel = -1; this.render(); this.liveEl.textContent = `${p.label}. ${readout(this.reps, this.a).live}`;
    }
  }

  // ── Layer 2 pathway profile ──────────────────────────────────────
  class PathwayProfile {
    drugs = CRS.drugs; pathways = CRS.pathways; idx = 0;
    btns: HTMLElement[]; profile: HTMLElement; rows: HTMLElement[]; live: HTMLElement;
    constructor(panel: HTMLElement) {
      panel.querySelector<HTMLElement>(".crs-pfallback")!.hidden = true;
      const wrap = panel.querySelector<HTMLElement>(".crs-pwrap")!; wrap.hidden = false;
      panel.classList.add("crs-ready");
      this.profile = panel.querySelector("#crs-profile")!;
      this.live = panel.querySelector("#crs-pw-live")!;
      this.profile.innerHTML = renderProfileRows(this.drugs, this.pathways[0].crs);
      this.rows = [...this.profile.querySelectorAll<HTMLElement>(".crs-prow")];
      this.btns = [...panel.querySelectorAll<HTMLElement>(".crs-pw-btn")];
      this.btns.forEach((b, i) => {
        b.addEventListener("click", () => this.select(i, false));
        b.addEventListener("keydown", (e) => {
          const n = e.key === "ArrowRight" || e.key === "ArrowDown" ? i + 1
            : e.key === "ArrowLeft" || e.key === "ArrowUp" ? i - 1 : -1;
          if (n < 0) return; e.preventDefault();
          this.select((n + this.btns.length) % this.btns.length, true);
        });
      });
    }
    select(i: number, focus: boolean) {
      this.idx = i;
      this.btns.forEach((b, j) => { const s = j === i; b.setAttribute("aria-checked", s ? "true" : "false"); b.classList.toggle("active", s); b.tabIndex = s ? 0 : -1; });
      if (focus) this.btns[i].focus();
      const crs = this.pathways[i].crs;
      this.rows.forEach((row, j) => {
        const c = crs[j] ?? 0;
        const g = row.querySelector(".crs-mk-g"); const mk = row.querySelector(".crs-mk"); const val = row.querySelector(".crs-pval");
        if (g) g.setAttribute("transform", `translate(${crsMiniX(c).toFixed(1)} 0)`);
        if (mk) mk.setAttribute("class", `crs-mk ${c > 0.05 ? "pos" : c < -0.05 ? "neg" : "zero"}`);
        if (val) val.textContent = fmtCRS(c);
      });
      this.live.textContent = `${this.pathways[i].label}. ${profileSummary(this.drugs, crs)}`;
    }
  }

  // ── Layer 3 distribution ─────────────────────────────────────────
  class DistributionView {
    pwIdx = 0; drugIdx = 0;
    density: SVGSVGElement; read: HTMLElement; live: HTMLElement;
    pwBtns: HTMLElement[]; drugBtns: HTMLElement[];
    constructor(panel: HTMLElement) {
      panel.querySelector<HTMLElement>(".crs-dfallback")!.hidden = true;
      panel.querySelector<HTMLElement>(".crs-dwrap")!.hidden = false;
      this.density = panel.querySelector("#crs-density")!;
      this.read = panel.querySelector("#crs-dread")!;
      this.live = panel.querySelector("#crs-dlive")!;
      this.pwBtns = [...panel.querySelectorAll<HTMLElement>(".crs-pw-btn")];
      this.drugBtns = [...panel.querySelectorAll<HTMLElement>(".crs-drug-btn")];
      this.wire(this.pwBtns, (i) => { this.pwIdx = i; this.update(true); });
      this.wire(this.drugBtns, (i) => { this.drugIdx = i; this.update(true); });
      this.update(false); // render initial state from JS (fresh, unique gradient id)
    }
    comps() {
      const key = `${CRS.pathways[this.pwIdx].id}:${CRS.drugs[this.drugIdx]}`;
      return (CRS.distributions as any)[key]?.components ?? genComponents(CRS.pathways[this.pwIdx].crs[this.drugIdx]);
    }
    update(announce: boolean) {
      const comps = this.comps();
      const point = CRS.pathways[this.pwIdx].crs[this.drugIdx];
      this.density.innerHTML = renderDensity(comps, point);
      const s = densityStats(comps);
      this.read.textContent = s.reading;
      if (announce) this.live.textContent = `${CRS.pathways[this.pwIdx].label}, ${CRS.drugs[this.drugIdx]}. CRS ${fmtCRS(point)}. ${s.reading}`;
    }
    sel(btns: HTMLElement[], i: number) {
      btns.forEach((b, j) => { const s = j === i; b.setAttribute("aria-checked", s ? "true" : "false"); b.classList.toggle("active", s); b.tabIndex = s ? 0 : -1; });
    }
    wire(btns: HTMLElement[], onSel: (i: number) => void) {
      btns.forEach((b, i) => {
        b.addEventListener("click", () => { this.sel(btns, i); onSel(i); });
        b.addEventListener("keydown", (e) => {
          const n = e.key === "ArrowRight" || e.key === "ArrowDown" ? i + 1
            : e.key === "ArrowLeft" || e.key === "ArrowUp" ? i - 1 : -1;
          if (n < 0) return; e.preventDefault();
          const ni = (n + btns.length) % btns.length; this.sel(btns, ni); btns[ni].focus(); onSel(ni);
        });
      });
    }
  }

  // ── Layer 4 context landscape ────────────────────────────────────
  class ContextField {
    ex = CRS.context.example; env = 0; inflam = 0;
    field: SVGSVGElement; markers: SVGGElement; mark!: SVGGElement;
    dens: SVGSVGElement; valEl: HTMLElement; readEl: HTMLElement; live: HTMLElement;
    constructor(panel: HTMLElement) {
      panel.querySelector<HTMLElement>(".crs-ffallback")!.hidden = true;
      panel.querySelector<HTMLElement>(".crs-fwrap")!.hidden = false;
      panel.classList.add("crs-ready");
      this.field = panel.querySelector("#crs-field")!;
      this.markers = this.field.querySelector(".crs-fmarkers")!;
      this.dens = panel.querySelector("#crs-fdens")!;
      this.valEl = panel.querySelector("#crs-fval")!;
      this.readEl = panel.querySelector("#crs-fread")!;
      this.live = panel.querySelector("#crs-flive")!;
      // swap the two static sample markers for one draggable marker
      this.markers.innerHTML = renderFieldMarker(this.env, this.inflam, this.ex, true);
      this.mark = this.markers.querySelector(".crs-fmark")!;
      this.field.addEventListener("pointerdown", (e) => this.startDrag(e));
      this.mark.addEventListener("keydown", (e) => this.onKey(e));
      this.update(false);
    }
    posFrom(clientX: number, clientY: number) {
      const r = this.field.getBoundingClientRect();
      this.env = clamp01(xToEnv(((clientX - r.left) / r.width) * FIELD.w));
      this.inflam = clamp01(yToInflam(((clientY - r.top) / r.height) * FIELD.h));
    }
    startDrag(e: PointerEvent) {
      e.preventDefault(); this.posFrom(e.clientX, e.clientY); this.update(false);
      this.mark.focus(); this.field.setPointerCapture?.(e.pointerId);
      const move = (ev: PointerEvent) => { this.posFrom(ev.clientX, ev.clientY); this.update(false); };
      const up = () => {
        this.field.releasePointerCapture?.(e.pointerId);
        this.field.removeEventListener("pointermove", move);
        this.field.removeEventListener("pointerup", up);
        this.update(true);
      };
      this.field.addEventListener("pointermove", move);
      this.field.addEventListener("pointerup", up);
    }
    onKey(e: KeyboardEvent) {
      const step = 0.05;
      if (e.key === "ArrowRight") this.env = clamp01(this.env + step);
      else if (e.key === "ArrowLeft") this.env = clamp01(this.env - step);
      else if (e.key === "ArrowUp") this.inflam = clamp01(this.inflam + step);
      else if (e.key === "ArrowDown") this.inflam = clamp01(this.inflam - step);
      else if (e.key === "Home") { this.env = 0; this.inflam = 0; }
      else if (e.key === "End") { this.env = 1; this.inflam = 1; }
      else return;
      e.preventDefault(); this.update(true);
    }
    label(c: number, confidence: string) {
      const [ax, ay] = CRS.context.axes;
      return `${ax.label} ${Math.round(this.env * 100)}% toward ${ax.to}, ${ay.label} ${Math.round(this.inflam * 100)}%. Local CRS ${fmtCRS(c)} — ${confidence}.`;
    }
    update(announce: boolean) {
      const c = localCrs(this.env, this.inflam, this.ex);
      this.mark.setAttribute("transform", `translate(${fieldX(this.env).toFixed(1)} ${fieldY(this.inflam).toFixed(1)})`);
      const dot = this.mark.querySelector(".crs-fmark-dot"); if (dot) dot.setAttribute("fill", fieldColor(c, this.ex.baseCrs));
      const v = this.mark.querySelector(".crs-fmark-val"); if (v) v.textContent = fmtCRS(c);
      const comps = genComponents(c), s = densityStats(comps);
      this.dens.innerHTML = renderDensity(comps, c);
      this.valEl.textContent = fmtCRS(c);
      this.readEl.textContent = s.reading;
      this.mark.setAttribute("aria-label", `Context marker. ${this.label(c, s.confidence)} Arrow keys move it.`);
      if (announce) this.live.textContent = `${this.label(c, s.confidence)} ${s.reading}`;
    }
  }

  // ── Layer 5: drag a marker along the path; live chart + ghost trace ──
  class DragWalk {
    cfg = CRS.layer5; n = CRS.layer5.walk.steps; axes = CRS.context.axes;
    tags = [0, 1].map((pw) => walkVolatility(walkValues(CRS.layer5, pw)) > 0.02);
    surfSvg: SVGSVGElement; surfLayer: HTMLElement; markerG: HTMLElement; tracesG: HTMLElement;
    valEl: HTMLElement; live: HTMLElement; plabel: HTMLElement; ptag: HTMLElement; pwBtns: HTMLElement[];
    trailPath!: SVGPathElement; walkerG!: SVGGElement; walkerDot!: SVGCircleElement;
    active = 0; t = [0, 0];
    constructor(panel: HTMLElement) {
      panel.querySelector<HTMLElement>(".crs-shiftfallback")!.hidden = true;
      panel.querySelector<HTMLElement>(".crs-dwrap2")!.hidden = false;
      this.surfSvg = panel.querySelector("#crs-dw-surf")!;
      this.surfLayer = panel.querySelector("#crs-dw-surflayer")!;
      this.markerG = panel.querySelector("#crs-dw-marker")!;
      this.tracesG = panel.querySelector("#crs-dw-traces")!;
      this.valEl = panel.querySelector("#crs-dw-val")!;
      this.live = panel.querySelector("#crs-dw-live")!;
      this.plabel = panel.querySelector("#crs-dw-plabel")!;
      this.ptag = panel.querySelector("#crs-dw-ptag")!;
      this.pwBtns = [...panel.querySelectorAll<HTMLElement>("[data-dw-pw]")];
      this.grabMarker();
      this.pwBtns.forEach((b, i) => {
        b.addEventListener("click", () => this.setPathway(i, false));
        b.addEventListener("keydown", (e) => {
          const nx = e.key === "ArrowRight" || e.key === "ArrowDown" ? i + 1
            : e.key === "ArrowLeft" || e.key === "ArrowUp" ? i - 1 : -1;
          if (nx < 0) return; e.preventDefault(); this.setPathway((nx + 2) % 2, true);
        });
      });
      panel.querySelector("#crs-dw-reset")!.addEventListener("click", () => this.reset());
      this.surfSvg.addEventListener("pointerdown", (e) => this.startDrag(e));
      this.draw(false);
    }
    grabMarker() {
      this.trailPath = this.markerG.querySelector(".crs-wtrail")!;
      this.walkerG = this.markerG.querySelector(".crs-walker")!;
      this.walkerDot = this.markerG.querySelector(".crs-walker-dot")!;
      this.walkerG.setAttribute("tabindex", "0");
      this.walkerG.setAttribute("role", "slider");
      this.walkerG.setAttribute("aria-label", "Marker position along the path from a lab medium to the inflamed chip");
      this.walkerG.setAttribute("aria-valuemin", "0");
      this.walkerG.setAttribute("aria-valuemax", "1");
      this.walkerG.addEventListener("keydown", (e) => this.onKey(e as KeyboardEvent));
    }
    tFromEvent(e: PointerEvent) {
      const r = this.surfSvg.getBoundingClientRect();
      return diagTFromXY(((e.clientX - r.left) / r.width) * FIELD.w, ((e.clientY - r.top) / r.height) * FIELD.h);
    }
    startDrag(e: PointerEvent) {
      e.preventDefault(); this.t[this.active] = this.tFromEvent(e); this.draw(false);
      this.walkerG.focus?.(); this.surfSvg.setPointerCapture?.(e.pointerId);
      const move = (ev: PointerEvent) => { this.t[this.active] = this.tFromEvent(ev); this.draw(false); };
      const up = () => {
        this.surfSvg.releasePointerCapture?.(e.pointerId);
        this.surfSvg.removeEventListener("pointermove", move);
        this.surfSvg.removeEventListener("pointerup", up);
        this.draw(true);
      };
      this.surfSvg.addEventListener("pointermove", move);
      this.surfSvg.addEventListener("pointerup", up);
    }
    onKey(e: KeyboardEvent) {
      const s = 1 / this.n; let t = this.t[this.active];
      if (e.key === "ArrowRight" || e.key === "ArrowUp") t += s;
      else if (e.key === "ArrowLeft" || e.key === "ArrowDown") t -= s;
      else if (e.key === "Home") t = 0; else if (e.key === "End") t = 1; else return;
      e.preventDefault(); this.t[this.active] = Math.max(0, Math.min(1, t)); this.draw(true);
    }
    setPathway(i: number, focus: boolean) {
      this.active = i;
      this.pwBtns.forEach((b, j) => { const sel = j === i; b.setAttribute("aria-checked", sel ? "true" : "false"); b.classList.toggle("active", sel); b.tabIndex = sel ? 0 : -1; });
      if (focus) this.pwBtns[i].focus();
      this.surfLayer.innerHTML = renderSurface(this.cfg, i, this.axes); // swap topography
      this.plabel.textContent = CRS.pathways[i].label;
      this.ptag.textContent = this.tags[i] ? "rugged" : "smooth";
      this.ptag.className = `crs-stag ${this.tags[i] ? "rugged" : "smooth"}`;
      this.draw(true);
    }
    draw(announce: boolean) {
      const tA = this.t[this.active], tG = this.t[1 - this.active];
      const x = fieldX(tA), y = fieldY(tA), cv = surfaceAt(tA, tA, this.cfg, this.active);
      this.trailPath.setAttribute("d", `M ${fieldX(0).toFixed(1)} ${fieldY(0).toFixed(1)} L ${x.toFixed(1)} ${y.toFixed(1)}`);
      this.walkerG.setAttribute("transform", `translate(${x.toFixed(1)} ${y.toFixed(1)})`);
      this.walkerDot.setAttribute("fill", surfaceColor(cv));
      this.tracesG.innerHTML = renderChartTraces(this.cfg, this.active, tA, tG);
      this.valEl.textContent = fmtCRS(cv);
      this.walkerG.setAttribute("aria-valuenow", tA.toFixed(2));
      this.walkerG.setAttribute("aria-valuetext", `${Math.round(tA * 100)}% along the path, CRS ${fmtCRS(cv)}`);
      if (announce) this.live.textContent = `${CRS.pathways[this.active].label}: ${Math.round(tA * 100)}% along the path. CRS ${fmtCRS(cv)}.`;
    }
    reset() { this.t = [0, 0]; this.draw(true); this.live.textContent = "Traces cleared."; }
  }

  const card = document.querySelector<HTMLElement>(".crs-card");
  if (card) {
    new Tabs(card);
    const l1 = card.querySelector<HTMLElement>("[data-crs-root]"); if (l1) new CrsCalc(l1);
    const l2 = card.querySelector<HTMLElement>("[data-crs-pathways]"); if (l2) new PathwayProfile(l2);
    const l3 = card.querySelector<HTMLElement>("[data-crs-dist]"); if (l3) new DistributionView(l3);
    const l4 = card.querySelector<HTMLElement>("[data-crs-context]"); if (l4) new ContextField(l4);
    const l5 = card.querySelector<HTMLElement>("[data-crs-shift]"); if (l5) new DragWalk(l5);
  }
</script>
