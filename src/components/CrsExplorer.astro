  .crs-field-wrap { display: flex; flex-direction: column; align-items: center; gap: var(--s-2); }
  .crs-field { width: 100%; max-width: 460px; height: auto; touch-action: none; display: block; }
  .crs-field :global(.crs-fband) { shape-rendering: geometricPrecision; }
  .crs-field :global(.crs-fcontour) { stroke: color-mix(in srgb, var(--ink) 40%, transparent); stroke-width: 1.1; fill: none; }
  .crs-field :global(.crs-fcontour.zero) { stroke: var(--ink); stroke-width: 1.8; stroke-dasharray: 5 4; }
  .crs-field :global(.crs-fframe) { fill: none; stroke: var(--ink); stroke-width: 1.3; }
  .crs-field :global(.crs-faxis) { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .03em; fill: var(--slate); }
  .crs-field :global(.crs-fmark) { cursor: grab; }
  .crs-field :global(.crs-fmark.is-draggable:focus-visible) { outline: none; }
  .crs-field :global(.crs-fmark.is-draggable:focus-visible .crs-fmark-halo) { stroke: var(--focus); stroke-width: 3; opacity: 1; }
