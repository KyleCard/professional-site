  .crs-density :global(.crs-dlab) { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .06em; text-transform: uppercase; fill: var(--slate); }
  .crs-density :global(.crs-dzero) { stroke: var(--slate); stroke-width: 1; stroke-dasharray: 3 3; }
  .crs-density :global(.crs-dmark-l) { stroke: var(--ink); stroke-width: 1.4; }
