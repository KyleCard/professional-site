  .crs-stag { font-family: var(--font-mono); font-size: .62rem; letter-spacing: .08em; text-transform: uppercase;
    padding: 2px 9px; border-radius: 100px; border: 1px solid var(--rule); color: var(--slate); }
  .crs-stag.smooth { border-color: color-mix(in srgb, var(--teal) 45%, var(--rule)); color: var(--teal); }
  .crs-stag.rugged { border-color: color-mix(in srgb, var(--amber-deep) 45%, var(--rule)); color: var(--amber-deep); }
  .crs-surface-svg { width: 100%; max-width: 380px; height: auto; display: block; touch-action: none; }
  .crs-surface-svg :global(.crs-scontour) { stroke: color-mix(in srgb, var(--ink) 32%, transparent); stroke-width: 1; fill: none; }
  .crs-surface-svg :global(.crs-scontour.zero) { stroke: var(--ink); stroke-width: 1.7; stroke-dasharray: 5 4; }
  .crs-surface-svg :global(.crs-fframe) { fill: none; stroke: var(--ink); stroke-width: 1.3; }
  .crs-surface-svg :global(.crs-faxis) { font-family: var(--font-mono); font-size: 10px; letter-spacing: .02em; fill: var(--slate); }
  .crs-surface-svg :global(.crs-diagguide) { stroke: var(--ink); stroke-width: 1; stroke-dasharray: 2 4; opacity: .35; }
  .crs-surface-svg :global(.crs-wtrail) { stroke: var(--ink); stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round;
    paint-order: stroke; }
  .crs-surface-svg :global(.crs-walker) { cursor: grab; }
  .crs-surface-svg :global(.crs-walker:focus-visible) { outline: none; }
  .crs-surface-svg :global(.crs-walker:focus-visible .crs-walker-halo) { stroke: var(--focus); stroke-width: 3; opacity: 1; }
  .crs-surface-svg :global(.crs-walker-halo) { fill: var(--paper-panel); stroke: var(--paper-panel); stroke-width: 2; opacity: .92; }
  .crs-surface-svg :global(.crs-walker-dot) { stroke: var(--ink); stroke-width: 2; }

  /* drag layout: surface + live chart side by side (stacks on mobile) */
  .crs-dwrap2[hidden], .crs-shiftfallback[hidden] { display: none; }
  .crs-shiftgrid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(16px, 3vw, 32px); align-items: start; margin-top: var(--s-2); }
  .crs-chartfig { margin: 0; display: flex; flex-direction: column; }
  .crs-chartfig .crs-pcol-h { margin-bottom: 8px; }
  .crs-chart-svg { width: 100%; max-width: 400px; height: auto; display: block; }
  .crs-chart-svg :global(.crs-caxis) { stroke: var(--ink-soft); stroke-width: 1.2; }
  .crs-chart-svg :global(.crs-czero) { stroke: var(--slate); stroke-width: 1; stroke-dasharray: 3 3; }
  .crs-chart-svg :global(.crs-clab) { font-family: var(--font-mono); font-size: 10px; fill: var(--slate); }
  .crs-chart-svg :global(.crs-ctitle) { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .08em; text-transform: uppercase; fill: var(--slate); }
  .crs-chart-svg :global(.crs-cxlab) { font-family: var(--font-mono); font-size: 9px; letter-spacing: .03em; fill: var(--slate); }
  /* ghost = the other pathway's trace: solid + muted teal, so it reads distinctly
     from both the dark active trace and the dashed CRS = 0 line */
  .crs-chart-svg :global(.crs-tghost) { stroke: var(--teal); stroke-width: 2; opacity: .5;
    stroke-linecap: round; stroke-linejoin: round; }
  .crs-chart-svg :global(.crs-tactive) { stroke: var(--ink); stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round; }

  .crs-dw-foot { display: flex; align-items: center; justify-content: center; gap: var(--s-4) var(--s-5); flex-wrap: wrap; margin-top: var(--s-4); }
  .crs-dw-readout { display: inline-flex; align-items: baseline; gap: 10px; margin: 0; }
  .crs-dw-readout .crs-cap { margin: 0; }
  .crs-dw-val { font-family: var(--font-display); font-weight: 500; line-height: 1; color: var(--ink);
    font-size: clamp(1.6rem, 1.2rem + 1.4vw, 2.2rem); }
  .crs-dw-reset { padding: 8px 16px; border: 1px solid var(--rule); background: var(--paper); color: var(--ink-soft);
    border-radius: var(--radius); font-size: .85rem; cursor: pointer; font-family: var(--font-body); transition: border-color .2s, color .2s; }
  .crs-dw-reset:hover { border-color: var(--teal); color: var(--teal); }
  .crs-clegend { font-size: .7rem; color: var(--slate); margin-top: 6px; }
  .crs-lg-active { color: var(--ink); }
  .crs-lg-ghost { color: var(--teal); }

  @media (max-width: 760px) {
    .crs-grid { grid-template-columns: 1fr; grid-template-areas: "plot" "out" "ctrl"; gap: var(--s-4); }
    .crs-side { align-self: stretch; flex-direction: row; flex-wrap: wrap; justify-content: space-between; gap: var(--s-3); }
    .crs-plot { max-width: 340px; }
    .crs-fgrid { grid-template-columns: 1fr; }
    .crs-fside { align-self: stretch; }
