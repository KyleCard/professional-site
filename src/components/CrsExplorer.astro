  /* ---- Layer 5 (predictability of the shift) ---- */
  .crs-twin { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(16px, 3vw, 34px); align-items: start; }
  .crs-spanel { margin: 0; display: flex; flex-direction: column; }
