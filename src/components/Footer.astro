---
import { Image } from "astro:assets";
import { SITE } from "../data/site";
import ccf from "../../assets/logos/logo-ccf.png";
import hhmi from "../../assets/logos/hhmi.png";
import sig from "../../assets/kjc_sig.png";
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="wrap inner">
    <div class="affil">
      <Image src={ccf} alt="Cleveland Clinic" class="logo logo-ccf" densities={[1, 2]} />
      <Image src={hhmi} alt="Howard Hughes Medical Institute" class="logo logo-hhmi" densities={[1, 2]} />
    </div>
    <div class="signoff">
      <Image src={sig} alt={`${SITE.fullName} signature`} class="sig" densities={[1, 2]} />
      <p class="mono cr">© {year} {SITE.fullName}</p>
    </div>
  </div>
</footer>

<style>
  .foot { position: relative; z-index: var(--z-content); margin-top: var(--s-8);
    padding: var(--s-5) 0; border-top: 1px solid var(--rule); background: var(--paper-cool); }
  .inner { display: flex; justify-content: space-between; align-items: flex-end; gap: var(--s-5); flex-wrap: wrap; }
  .affil { display: flex; gap: var(--s-4); align-items: center; flex-wrap: wrap; }
  .logo { width: auto; opacity: .85; }
  .logo-ccf { height: 45px; }
  .logo-hhmi { height: 48px; }
  .signoff { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
  .sig { height: 60px; width: auto; opacity: .9; }
  .cr { color: var(--ink-faint); }
  @media (max-width: 640px) {
    .inner { justify-content: flex-start; gap: var(--s-4); }
    .signoff { align-items: flex-start; }
  }
</style>
