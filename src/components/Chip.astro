---
// Evolution-on-a-Chip — a graphical abstract for the summit.
// A stylized CF airway-on-a-chip cross-section above a five-beat process drawn as
// a small adaptive walk (slate → teal → amber), echoing the page's trajectory.
const steps = [
  { k: "Seed",     d: "Establish P. aeruginosa in the CF airway chip", x: 150 },
  { k: "Pressure", d: "Apply clinically realistic antibiotic selection", x: 322 },
  { k: "Evolve",   d: "Experimental evolution in within-host conditions", x: 494 },
  { k: "Read out", d: "Functional genomics + phenotypic screens", x: 666 },
  { k: "Forecast", d: "Predict — and steer — resistance", x: 838, peak: true },
];
const colorAt = (i: number) => (i < 2 ? "var(--slate)" : i < 4 ? "var(--teal)" : "var(--amber)");
---
<figure class="chip">
  <figcaption class="chip-cap mono">A graphical abstract</figcaption>
  <svg viewBox="0 0 980 520" role="img" aria-labelledby="chip-title chip-desc" class="chip-svg">
    <title id="chip-title">Evolution-on-a-Chip</title>
    <desc id="chip-desc">A cystic-fibrosis airway-on-a-chip feeds a five-step program: seed, pressure, evolve,
      read out, and forecast — predicting and steering the evolution of antibiotic resistance.</desc>

    <!-- ── the organ chip (cross-section) ───────────────────────── -->
    <g class="organ">
      <rect x="120" y="44" width="740" height="150" rx="16" class="chip-body" />
      <!-- airway (top) channel: epithelium + CF mucus + air-liquid interface -->
      <rect x="140" y="64" width="700" height="48" rx="8" class="ch-air" />
      <path class="mucus" d="M150 100 Q 250 86 360 99 T 580 99 T 820 97 L 830 110 L 150 110 Z" />
      <!-- porous membrane -->
      <line x1="140" y1="118" x2="840" y2="118" class="membrane" />
      <!-- perfusion (bottom) channel -->
      <rect x="140" y="124" width="700" height="48" rx="8" class="ch-media" />
      <path class="flow" d="M150 148 H 830" />
      <!-- epithelial cells on the membrane -->
      <g class="cells">
        {Array.from({ length: 22 }).map((_, i) => (
          <circle cx={156 + i * 31} cy={114} r="5.5" />
        ))}
      </g>
      <!-- P. aeruginosa colonizing the airway -->
      <g class="bugs">
        {[180, 250, 305, 360, 430, 520, 600, 690, 770].map((x, i) => (
          <rect x={x} y={88 + (i % 3) * 5} width="9" height="3.6" rx="1.8" transform={`rotate(${(i * 37) % 90} ${x + 4} ${90 + (i % 3) * 5})`} />
        ))}
      </g>
      <!-- ports -->
      <circle cx="120" cy="88" r="9" class="port" /><circle cx="860" cy="88" r="9" class="port" />
      <circle cx="120" cy="148" r="9" class="port" /><circle cx="860" cy="148" r="9" class="port" />
      <!-- labels -->
      <text x="150" y="40" class="anno">airway epithelium · CF mucus · air–liquid interface</text>
      <text x="150" y="190" class="anno">vascular perfusion</text>
      <text x="690" y="80" class="anno"><tspan class="sp-i">P. aeruginosa</tspan></text>
    </g>

    <!-- ── the process as a small adaptive walk ─────────────────── -->
    <g class="walk">
      <line x1="150" y1="300" x2="838" y2="300" class="walk-base" />
      <line x1="150" y1="300" x2="838" y2="300" class="walk-draw" />
      {steps.map((s, i) => (
        <g class="node" style={`--i:${i}`}>
          <line x1={s.x} y1="194" x2={s.x} y2="300" class="stem" />
          <circle cx={s.x} cy="300" r={s.peak ? 11 : 8} fill={colorAt(i)} class="dot" />
          {s.peak && <circle cx={s.x} cy="300" r="17" class="halo" />}
          <text x={s.x} y="338" class="step-k" style={`fill:${colorAt(i)}`}>{`0${i + 1} · ${s.k}`}</text>
          <foreignObject x={s.x - 82} y="348" width="164" height="120">
            <p class="step-d" xmlns="http://www.w3.org/1999/xhtml">{s.d}</p>
          </foreignObject>
        </g>
      ))}
    </g>
  </svg>
</figure>

<style>
  .chip { margin: 30px 0 8px; }
  .chip-cap { color: var(--slate); margin-bottom: 14px; }
  .chip-svg { width: 100%; height: auto; overflow: visible; }

  .chip-body { fill: var(--paper); stroke: var(--ink); stroke-width: 1.4; }
  .ch-air { fill: color-mix(in srgb, var(--teal-soft) 22%, var(--paper)); }
  .ch-media { fill: color-mix(in srgb, var(--slate) 16%, var(--paper)); }
  .mucus { fill: color-mix(in srgb, var(--teal-soft) 30%, transparent); }
  .membrane { stroke: var(--ink); stroke-width: 1.2; stroke-dasharray: 3 4; opacity: .7; }
  .cells circle { fill: color-mix(in srgb, var(--teal-soft) 55%, var(--paper)); stroke: var(--ink); stroke-width: .6; }
  .bugs rect { fill: var(--teal-deep); }
  .port { fill: var(--paper-panel); stroke: var(--ink); stroke-width: 1.4; }
  .flow { stroke: var(--slate); stroke-width: 2; stroke-dasharray: 5 9; opacity: .55; }
  .anno { font-family: var(--font-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; fill: var(--ink-faint); }
  .anno .sp-i { font-style: italic; text-transform: none; letter-spacing: .02em; }

  .walk-base { stroke: var(--rule); stroke-width: 2; stroke-dasharray: 1 7; stroke-linecap: round; }
  .walk-draw { stroke: var(--teal); stroke-width: 2.4; stroke-linecap: round;
    stroke-dasharray: 688; stroke-dashoffset: 688; }
  .stem { stroke: var(--rule); stroke-width: 1; stroke-dasharray: 2 3; }
  .dot { stroke: var(--paper); stroke-width: 2; }
  .halo { fill: none; stroke: var(--amber); stroke-width: 1.4; opacity: .5; }
  .step-k { font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: .12em;
    text-transform: uppercase; text-anchor: middle; }
  .step-d { margin: 6px 0 0; font-family: var(--font-body); font-size: 12.5px; line-height: 1.35;
    color: var(--ink-soft); text-align: center; }

  /* subtle, on-view motion (a journal abstract, not a tech demo) */
  .chip-svg .node { opacity: 0; transform: translateY(8px); }
  .chip-svg.in .walk-draw { animation: draw 1.4s ease forwards; }
  .chip-svg.in .node { animation: pop .5s ease forwards; animation-delay: calc(var(--i) * 0.16s + 0.3s); }
  .chip-svg.in .flow { animation: flow 2.2s linear infinite; }
  @keyframes draw { to { stroke-dashoffset: 0; } }
  @keyframes pop { to { opacity: 1; transform: none; } }
  @keyframes flow { to { stroke-dashoffset: -28; } }

  @media (prefers-reduced-motion: reduce) {
    .chip-svg .node { opacity: 1; transform: none; }
    .walk-draw { stroke-dashoffset: 0; }
    .chip-svg.in .walk-draw, .chip-svg.in .node, .chip-svg.in .flow { animation: none; }
  }
  @media (max-width: 560px) { .step-d { font-size: 10.5px; } .step-k { font-size: 10px; } }
</style>

<script>
  // play the abstract once when it scrolls into view
  const svg = document.currentScript?.previousElementSibling?.querySelector?.(".chip-svg")
    || document.querySelector(".chip-svg");
  if (svg) {
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) svg.classList.add("in");
    else {
      const io = new IntersectionObserver((es) => es.forEach((e) => {
        if (e.isIntersecting) { svg.classList.add("in"); io.disconnect(); }
      }), { threshold: 0.3 });
      io.observe(svg);
    }
  }
</script>
