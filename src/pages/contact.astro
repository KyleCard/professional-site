---
import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
import { SITE, LINKS, CV_PDF } from "../data/site";
import clevelandMap from "../../assets/cleveland_map.png";
const mapsUrl = "https://www.google.com/maps/search/?api=1&query=Cleveland+Clinic+Lerner+Research+Institute+9500+Euclid+Ave+Cleveland+OH+44195";
---
<Base title="Contact" description="Contact Kyle J. Card — collaborations, prospective students, and talks.">
  <section class="contact wrap">
    <p class="eyebrow mono reveal">Contact</p>
    <h1 class="big reveal">Let's chat.</h1>
    <p class="lead measure reveal">
      I'm always happy to hear from prospective students and collaborators working on the evolution of
      resistance. Email is the best way to reach me.
    </p>

    <div class="ctop">
      <div class="cleft">
        <a class="bigmail reveal" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        <div class="links reveal">
          <a href={LINKS.scholar} target="_blank" rel="noopener">Google Scholar ↗</a>
          <a href={CV_PDF} download>Curriculum Vitae (PDF) ↓</a>
          <a href="/cv">CV — full record →</a>
        </div>
      </div>

      <figure class="map reveal">
        <a class="map-frame" href={mapsUrl} target="_blank" rel="noopener" aria-label="Open the Cleveland Clinic location in Google Maps">
          <Image src={clevelandMap} alt="Map of Cleveland with the Cleveland Clinic pinned on Euclid Avenue." class="map-img" widths={[480, 760, 1100]} sizes="(max-width: 820px) 100vw, 560px" />
        </a>
        <figcaption class="map-cap">
          <p class="map-org">Cleveland Clinic Research</p>
          <p class="map-addr mono">9500 Euclid Ave · Cleveland, OH 44195</p>
          <a class="map-link" href={mapsUrl} target="_blank" rel="noopener">Open in Google Maps ↗</a>
        </figcaption>
      </figure>
    </div>
  </section>
</Base>

<style>
  .contact { padding-top: var(--page-top); padding-bottom: var(--s-7); }
  /* tuck the kicker into the space above so the h1 lands at --page-top like the other pages */
  .eyebrow { color: var(--slate); margin-top: calc(-1lh - var(--s-3)); margin-bottom: var(--s-3); }
  .big { font-size: var(--t-h1); margin-bottom: var(--s-3); }
  .lead { color: var(--ink-soft); font-size: var(--t-lede); margin-bottom: var(--s-6); }

  .ctop { display: grid; grid-template-columns: 1fr 1.05fr; gap: clamp(28px, 5vw, 72px); align-items: center;
    border-top: 1px solid var(--rule); padding-top: var(--s-6); }
  .cleft { display: flex; flex-direction: column; }
  .bigmail { font-family: var(--font-display); font-weight: 400;
    font-size: clamp(1.5rem, .8rem + 2.6vw, 2.8rem); color: var(--ink); text-decoration: none; letter-spacing: -.01em;
    border-bottom: 2px solid var(--teal); padding-bottom: 6px; margin-bottom: var(--s-5); align-self: flex-start; }
  .bigmail:hover { color: var(--teal); }
  .links { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
  .links a { color: var(--ink); text-decoration: none; }
  .links a:hover { color: var(--teal); text-decoration: underline; text-underline-offset: 3px; }

  /* map (Kyle's screenshot, framed to match the page) */
  .map { margin: 0; }
  .map-frame { display: block; border: 1px solid var(--rule); border-radius: var(--radius); overflow: hidden;
    box-shadow: 0 18px 44px -32px rgba(34, 45, 42, .55); }
  .map-img { width: 100%; height: auto; display: block; transition: transform .5s ease; }
  .map-frame:hover .map-img { transform: scale(1.03); }
  .map-cap { margin-top: var(--s-3); }
  .map-org { color: var(--ink); font-weight: 500; }
  .map-addr { color: var(--slate); letter-spacing: .1em; margin: 4px 0 8px; }
  .map-link { color: var(--teal); text-decoration: none; font-size: .95rem; }
  .map-link:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 820px) {
    .ctop { grid-template-columns: 1fr; gap: var(--s-5); }
  }
</style>
