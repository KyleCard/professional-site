---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", (p) => !p.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const imgs = import.meta.glob<{ default: ImageMetadata }>("../../../assets/blog/*.{jpg,jpeg,png,webp}", { eager: true });
const img = post.data.image
  ? Object.entries(imgs).find(([p]) => p.endsWith("/" + post.data.image))?.[1].default
  : undefined;
const fmt = (d: Date) => new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" }).format(d);
---
<Base title={post.data.title} description={post.data.description}>
  <article class="post wrap">
    <a class="back mono" href="/blog">← Field notes</a>

    <header class="phead">
      <p class="pdate mono">{fmt(post.data.date)}{post.data.video ? " · Talk" : " · Essay"}</p>
      <h1 class="ptitle">{post.data.title}</h1>
      <p class="plede measure">{post.data.description}</p>
    </header>

    {post.data.video ? (
      <div class="video">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${post.data.video}`}
          title={post.data.title}
          loading="lazy"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    ) : img ? (
      <Image src={img} alt="" class="phero" widths={[480, 900, 1200]} sizes="(max-width: 760px) 100vw, 760px" />
    ) : null}

    <div class="prose">
      <Content />
    </div>

    <footer class="pfoot">
      <a class="back mono" href="/blog">← All field notes</a>
    </footer>
  </article>
</Base>

<style>
  .post { padding-top: var(--page-top); padding-bottom: var(--s-8); max-width: 820px; }
  .back { color: var(--slate); text-decoration: none; display: inline-block; }
  .back:hover { color: var(--teal); }

  .phead { margin: var(--s-4) 0 var(--s-5); }
  .pdate { color: var(--slate); margin-bottom: var(--s-2); }
  .ptitle { font-size: var(--t-h2); line-height: 1.04; margin-bottom: var(--s-3); }
  .plede { color: var(--ink-soft); font-size: var(--t-lede); }

  .video { position: relative; aspect-ratio: 16 / 9; margin: var(--s-4) 0 var(--s-6);
    border-radius: var(--radius); overflow: hidden; border: 1px solid var(--rule); background: var(--plate); }
  .video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .phero { width: 100%; height: auto; border-radius: var(--radius); margin: var(--s-4) 0 var(--s-6);
    border: 1px solid var(--rule); }

  /* article prose */
  .prose { max-width: var(--measure); font-size: 1.06rem; line-height: 1.72; color: var(--ink); }
  .prose :global(p) { margin-bottom: var(--s-3); }
  .prose :global(a) { color: var(--teal); text-decoration: underline; text-decoration-color: var(--rule);
    text-underline-offset: 3px; }
  .prose :global(a:hover) { text-decoration-color: var(--teal); color: var(--teal-deep); }
  .prose :global(blockquote) { margin: var(--s-4) 0; padding: 4px 0 4px var(--s-3);
    border-left: 3px solid var(--teal); color: var(--ink-soft); font-style: italic; }
  .prose :global(blockquote p:last-child) { margin-bottom: 0; }
  .prose :global(h2) { font-size: var(--t-h3); margin: var(--s-5) 0 var(--s-2); }
  .prose :global(em), .prose :global(i) { font-style: italic; }

  .pfoot { margin-top: var(--s-6); padding-top: var(--s-4); border-top: 1px solid var(--rule); }
</style>
