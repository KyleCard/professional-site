---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const imgs = import.meta.glob<{ default: ImageMetadata }>("../../../assets/blog/*.{jpg,jpeg,png,webp}", { eager: true });
const imgFor = (f?: string) => (f ? Object.entries(imgs).find(([p]) => p.endsWith("/" + f))?.[1].default : undefined);
const fmt = (d: Date) => new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" }).format(d);
---
<Base title="Field notes" description="Essays and recorded talks by Kyle J. Card on evolution, antibiotic resistance, responsible science, and disability in STEM.">
  <section class="blog wrap">
    <p class="eyebrow mono reveal">Field notes</p>
    <h1 class="big reveal">Writing &amp; talks.</h1>
    <p class="lead measure reveal">Essays and recorded talks on the evolution of antibiotic resistance, the
      responsible conduct of research, and disability in science.</p>

    <ul class="posts" role="list">
      {posts.map((p) => {
        const img = imgFor(p.data.image);
        return (
          <li class="post reveal">
            <a class="plink" href={`/blog/${p.id}/`}>
              {img && (
                <div class="thumb">
                  <Image src={img} alt="" width={520} height={320} class="thumb-img" />
                  {p.data.video && <span class="vbadge mono">▶ Video</span>}
                </div>
              )}
              <div class="meta">
                <p class="pdate mono">{fmt(p.data.date)}</p>
                <h2 class="pt">{p.data.title}</h2>
                <p class="pd">{p.data.description}</p>
                <span class="more mono">Read →</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</Base>

<style>
  .blog { padding-top: clamp(96px, 16vh, 168px); padding-bottom: var(--s-8); }
  .eyebrow { color: var(--slate); margin-bottom: var(--s-3); }
  .big { font-size: var(--t-h1); margin-bottom: var(--s-3); }
  .lead { color: var(--ink-soft); font-size: var(--t-lede); margin-bottom: var(--s-6); }

  .posts { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--s-5);
    border-top: 1px solid var(--rule); }
  .post { border-bottom: 1px solid var(--rule-soft); padding-bottom: var(--s-5); }
  .plink { display: grid; grid-template-columns: 300px 1fr; gap: var(--s-5); align-items: center;
    text-decoration: none; color: inherit; padding-top: var(--s-5); }
  .thumb { position: relative; aspect-ratio: 16 / 10; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--rule); background: var(--paper-panel); }
  .thumb-img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; filter: saturate(.95); }
  .plink:hover .thumb-img { transform: scale(1.04); }
  .vbadge { position: absolute; left: 10px; bottom: 10px; background: color-mix(in srgb, var(--ink) 86%, transparent);
    color: var(--paper); padding: 4px 10px; border-radius: 100px; font-size: .58rem; }
  .pdate { color: var(--slate); margin-bottom: 8px; }
  .pt { font-size: var(--t-h3); line-height: 1.1; margin-bottom: 10px; color: var(--ink); transition: color .2s; }
  .plink:hover .pt { color: var(--teal); }
  .pd { color: var(--ink-soft); font-size: .98rem; max-width: 46ch; margin-bottom: 14px; }
  .more { color: var(--teal); }

  @media (max-width: 720px) {
    .plink { grid-template-columns: 1fr; gap: var(--s-3); }
    .thumb { aspect-ratio: 16 / 9; }
  }
</style>
